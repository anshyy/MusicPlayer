<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Friends"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your QR Code to add friends"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/ivQRCode"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:src="@android:drawable/ic_menu_share"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnScanFriend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan Friend's QR Code"
        android:backgroundTint="@color/accent_primary"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent Friends"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        android:layout_gravity="start"/>

    <!-- Placeholder for friends list -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No friends added yet. Start scanning!"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>
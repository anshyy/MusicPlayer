<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:paddingHorizontal="24dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvSongNumber"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:text="01"
        android:textColor="@color/text_tertiary"
        android:textSize="14sp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvSongArt"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/tvSongNumber"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/ivSongArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/gradient_card_pop" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/cvSongArt"
        android:layout_toStartOf="@+id/btnMore"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSongName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Song Title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvArtistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Artist Name"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_more"
        app:tint="@color/text_tertiary" />

    <!-- Hidden Like button for logic compatibility -->
    <ImageButton
        android:id="@+id/btnLike"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

</RelativeLayout>
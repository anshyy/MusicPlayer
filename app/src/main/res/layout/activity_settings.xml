<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <!-- Playback Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Playback"
            android:textColor="@color/accent_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shuffle Mode"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchShuffle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:thumbTint="@color/accent_primary"
                app:trackTint="@color/accent_secondary"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repeat Mode"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchRepeat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:thumbTint="@color/accent_primary"
                app:trackTint="@color/accent_secondary"/>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="16dp"/>

        <!-- Audio Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio"
            android:textColor="@color/accent_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/btnAudioQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio Quality"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/tvCurrentQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatic"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnEqualizer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equalizer"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adjust audio frequency"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="16dp"/>

        <!-- Advanced Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced"
            android:textColor="@color/accent_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gapless Playback"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchGapless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:thumbTint="@color/accent_primary"
                app:trackTint="@color/accent_secondary"/>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/btnCrossfade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crossfade"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/tvCrossfadeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Off"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio Normalization"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchNormalization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:thumbTint="@color/accent_primary"
                app:trackTint="@color/accent_secondary"/>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="16dp"/>

        <!-- Others -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Others"
            android:textColor="@color/accent_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/btnSleepTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sleep Timer"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/tvSleepTimerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Off"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>